{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "jsx": "react-native",
    "strict": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@amortisation": [
        "./packages/amortisation/index"
      ],
      "@amortisation/*": [
        "./packages/amortisation/*"
      ],
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
