{
  "name": "loanbee-mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest --watchAll=false",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "jest": {
    "coverageProvider": "v8",
    "collectCoverageFrom": [
      "app/**/*.{ts,tsx}",
      "src/**/*.{ts,tsx}",
      "!src/**/*.d.ts",
      "!src/**/__mocks__/**",
      "!src/i18n/locales/**",
      "!src/core/**"
    ],
    "projects": [
      {
        "displayName": "core",
        "testMatch": [
          "<rootDir>/__tests__/core/**/*.test.ts"
        ],
        "modulePathIgnorePatterns": [
          "<rootDir>/.worktrees/"
        ],
        "testEnvironment": "node",
        "moduleNameMapper": {
          "^@oskarfigura/amortisation$": "<rootDir>/node_modules/@oskarfigura/amortisation/dist/index.js",
          "^@oskarfigura/amortisation/(.*)$": "<rootDir>/node_modules/@oskarfigura/amortisation/dist/$1.js",
          "^@oskarfigura/icons$": "<rootDir>/node_modules/@oskarfigura/icons/dist/index.js",
          "^@oskarfigura/icons/(.*)$": "<rootDir>/node_modules/@oskarfigura/icons/dist/$1.js",
          "^@oskarfigura/ui-native$": "<rootDir>/node_modules/@oskarfigura/ui-native/dist/index.js",
          "^@oskarfigura/ui-native/(.*)$": "<rootDir>/node_modules/@oskarfigura/ui-native/dist/$1.js",
          "^@/(.*)$": "<rootDir>/src/$1"
        },
        "transform": {
          "^.+\\.tsx?$": [
            "ts-jest"
          ],
          "^.+\\.jsx?$": [
            "ts-jest",
            {
              "tsconfig": {
                "allowJs": true
              }
            }
          ]
        },
        "transformIgnorePatterns": [
          "node_modules/(?!@oskarfigura/(amortisation|icons|ui-native)/)"
        ]
      },
      {
        "displayName": "storage",
        "testMatch": [
          "<rootDir>/__tests__/storage/**/*.test.ts"
        ],
        "modulePathIgnorePatterns": [
          "<rootDir>/.worktrees/"
        ],
        "testEnvironment": "node",
        "moduleNameMapper": {
          "^@oskarfigura/amortisation$": "<rootDir>/node_modules/@oskarfigura/amortisation/dist/index.js",
          "^@oskarfigura/amortisation/(.*)$": "<rootDir>/node_modules/@oskarfigura/amortisation/dist/$1.js",
          "^@oskarfigura/icons$": "<rootDir>/node_modules/@oskarfigura/icons/dist/index.js",
          "^@oskarfigura/icons/(.*)$": "<rootDir>/node_modules/@oskarfigura/icons/dist/$1.js",
          "^@oskarfigura/ui-native$": "<rootDir>/node_modules/@oskarfigura/ui-native/dist/index.js",
          "^@oskarfigura/ui-native/(.*)$": "<rootDir>/node_modules/@oskarfigura/ui-native/dist/$1.js",
          "^@/(.*)$": "<rootDir>/src/$1",
          "^react-native-mmkv$": "<rootDir>/src/__mocks__/react-native-mmkv.ts"
        },
        "transform": {
          "^.+\\.tsx?$": [
            "ts-jest"
          ],
          "^.+\\.jsx?$": [
            "ts-jest",
            {
              "tsconfig": {
                "allowJs": true
              }
            }
          ]
        },
        "transformIgnorePatterns": [
          "node_modules/(?!@oskarfigura/(amortisation|icons|ui-native)/)"
        ]
      },
      {
        "displayName": "display",
        "testMatch": [
          "<rootDir>/__tests__/display/**/*.test.ts"
        ],
        "modulePathIgnorePatterns": [
          "<rootDir>/.worktrees/"
        ],
        "testEnvironment": "node",
        "moduleNameMapper": {
          "^@oskarfigura/amortisation$": "<rootDir>/node_modules/@oskarfigura/amortisation/dist/index.js",
          "^@oskarfigura/amortisation/(.*)$": "<rootDir>/node_modules/@oskarfigura/amortisation/dist/$1.js",
          "^@oskarfigura/icons$": "<rootDir>/node_modules/@oskarfigura/icons/dist/index.js",
          "^@oskarfigura/icons/(.*)$": "<rootDir>/node_modules/@oskarfigura/icons/dist/$1.js",
          "^@oskarfigura/ui-native$": "<rootDir>/node_modules/@oskarfigura/ui-native/dist/index.js",
          "^@oskarfigura/ui-native/(.*)$": "<rootDir>/node_modules/@oskarfigura/ui-native/dist/$1.js",
          "^@/(.*)$": "<rootDir>/src/$1"
        },
        "transform": {
          "^.+\\.tsx?$": [
            "ts-jest"
          ],
          "^.+\\.jsx?$": [
            "ts-jest",
            {
              "tsconfig": {
                "allowJs": true
              }
            }
          ]
        },
        "transformIgnorePatterns": [
          "node_modules/(?!@oskarfigura/(amortisation|icons|ui-native)/)"
        ]
      },
      {
        "displayName": "design-system",
        "testMatch": [
          "<rootDir>/__tests__/design-system/**/*.test.ts"
        ],
        "modulePathIgnorePatterns": [
          "<rootDir>/.worktrees/"
        ],
        "testEnvironment": "node",
        "moduleNameMapper": {
          "^@oskarfigura/amortisation$": "<rootDir>/node_modules/@oskarfigura/amortisation/dist/index.js",
          "^@oskarfigura/amortisation/(.*)$": "<rootDir>/node_modules/@oskarfigura/amortisation/dist/$1.js",
          "^@oskarfigura/icons$": "<rootDir>/node_modules/@oskarfigura/icons/dist/index.js",
          "^@oskarfigura/icons/(.*)$": "<rootDir>/node_modules/@oskarfigura/icons/dist/$1.js",
          "^@oskarfigura/ui-native$": "<rootDir>/node_modules/@oskarfigura/ui-native/dist/index.js",
          "^@oskarfigura/ui-native/(.*)$": "<rootDir>/node_modules/@oskarfigura/ui-native/dist/$1.js",
          "^@/(.*)$": "<rootDir>/src/$1"
        },
        "transform": {
          "^.+\\.tsx?$": [
            "ts-jest"
          ],
          "^.+\\.jsx?$": [
            "ts-jest",
            {
              "tsconfig": {
                "allowJs": true
              }
            }
          ]
        },
        "transformIgnorePatterns": [
          "node_modules/(?!@oskarfigura/(amortisation|icons|ui-native)/)"
        ]
      },
      {
        "displayName": "screens",
        "testMatch": [
          "<rootDir>/__tests__/screens/**/*.test.tsx"
        ],
        "modulePathIgnorePatterns": [
          "<rootDir>/.worktrees/"
        ],
        "testEnvironment": "node",
        "moduleNameMapper": {
          "^@oskarfigura/amortisation$": "<rootDir>/node_modules/@oskarfigura/amortisation/dist/index.js",
          "^@oskarfigura/amortisation/(.*)$": "<rootDir>/node_modules/@oskarfigura/amortisation/dist/$1.js",
          "^@oskarfigura/icons$": "<rootDir>/node_modules/@oskarfigura/icons/dist/index.js",
          "^@oskarfigura/icons/(.*)$": "<rootDir>/node_modules/@oskarfigura/icons/dist/$1.js",
          "^@oskarfigura/ui-native$": "<rootDir>/src/__mocks__/ui-native.ts",
          "^@oskarfigura/ui-native/(.*)$": "<rootDir>/node_modules/@oskarfigura/ui-native/dist/$1.js",
          "^@/(.*)$": "<rootDir>/src/$1",
          "^react-native-mmkv$": "<rootDir>/src/__mocks__/react-native-mmkv.ts"
        },
        "transform": {
          "^.+\\.tsx?$": [
            "ts-jest",
            {
              "tsconfig": {
                "jsx": "react"
              }
            }
          ],
          "^.+\\.jsx?$": [
            "ts-jest",
            {
              "tsconfig": {
                "allowJs": true,
                "jsx": "react"
              }
            }
          ]
        },
        "transformIgnorePatterns": [
          "node_modules/(?!@oskarfigura/(amortisation|icons|ui-native)/)"
        ]
      }
    ]
  },
  "dependencies": {
    "@expo-google-fonts/manrope": "^0.4.2",
    "@hookform/resolvers": "^5.2.2",
    "@oskarfigura/amortisation": "^1.0.1",
    "@oskarfigura/icons": "^1.4.2",
    "@oskarfigura/ui-native": "^0.2.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.6.0",
    "expo": "~55.0.26",
    "expo-constants": "~55.0.15",
    "expo-document-picker": "~55.0.13",
    "expo-file-system": "~55.0.22",
    "expo-font": "~55.0.6",
    "expo-linear-gradient": "~55.0.14",
    "expo-linking": "~55.0.15",
    "expo-localization": "~55.0.14",
    "expo-router": "~55.0.16",
    "expo-screen-orientation": "~55.0.15",
    "expo-sharing": "~55.0.20",
    "expo-splash-screen": "~55.0.21",
    "expo-store-review": "~55.0.14",
    "expo-system-ui": "~55.0.18",
    "expo-tracking-transparency": "~55.0.14",
    "expo-web-browser": "~55.0.16",
    "i18next": "^26.0.8",
    "react": "19.2.0",
    "react-hook-form": "^7.74.0",
    "react-i18next": "^17.0.6",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-gifted-charts": "^1.4.76",
    "react-native-google-mobile-ads": "^16.3.3",
    "react-native-keyboard-controller": "1.20.7",
    "react-native-mmkv": "^4.3.1",
    "react-native-nitro-modules": "^0.35.9",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-worklets": "0.7.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@jest/globals": "^29.7.0",
    "@types/react": "^19.2.14",
    "@types/react-test-renderer": "^19.1.0",
    "jest": "^29.7.0",
    "react-dom": "^19.2.0",
    "react-test-renderer": "^19.2.0",
    "sharp": "^0.34.5",
    "ts-jest": "^29.4.9",
    "typescript": "~5.9.2"
  },
  "private": true
}
